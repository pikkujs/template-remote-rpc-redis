{
  "name": "test-app",
  "type": "module",
  "private": true,
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@pikku/addon-console": "workspace:*",
    "@pikku/addon-graph": "workspace:*",
    "@pikku/auth-js": "^0.12.5",
    "@pikku/core": "^0.12.31",
    "@pikku/jose": "^0.12.3",
    "@pikku/schema-cfworker": "^0.12.2",
    "eventsource": "^4.1.0",
    "ws": "^8.19.0",
    "zod": "^4",
    "@pikku/express": "^0.12.5",
    "@pikku/redis": "^0.12.7",
    "ioredis": "^5.10.0",
    "pino-pretty": "^13.1.3",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@pikku/cli": "^0.12.35",
    "@pikku/cloudflare": "workspace:*",
    "@pikku/deploy-cloudflare": "workspace:*",
    "@pikku/deploy-serverless": "workspace:*",
    "@pikku/deploy-standalone": "workspace:*",
    "@pikku/fetch": "^0.12.3",
    "@pikku/lambda": "workspace:*",
    "@pikku/modelcontextprotocol": "workspace:*",
    "@pikku/node-http-server": "workspace:*",
    "@pikku/schedule": "workspace:*",
    "@pikku/websocket": "^0.12.1",
    "@types/node": "^24",
    "@types/ws": "^8",
    "concurrently": "^9.2.1",
    "serverless": "^4.33.0",
    "serverless-offline": "^14.5.0",
    "serverless-offline-sqs": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9",
    "wrangler": "^4.78.0"
  },
  "scripts": {
    "build": "tsc -b",
    "ncu:pikku": "npx npm-check-updates -f '/@pikku/.*/'",
    "pikku": "pikku all",
    "test:http-fetch": "tsx client/test-remote-rpc.ts",
    "test:http-sse": "npx tsx client/http-sse.ts",
    "test:mcp": "npx tsx client/mcp.ts",
    "test:mcp:http": "npx tsx client/mcp-http.ts",
    "test:queue": "npx tsx client/queue.ts",
    "test:rpc": "npx tsx client/rpc.ts",
    "test:runtime-rpc": "npx tsx client/runtime-rpc.ts",
    "test:websocket": "npx tsx client/websocket.ts",
    "test:cli:local": "npx tsx client/cli-local.gen.ts",
    "test:cli:raw": "npx tsx client/cli-raw.ts list",
    "test:workflows": "npx tsx client/workflow.ts",
    "test:triggers": "npx tsx client/trigger.ts",
    "test:agent-http": "npx tsx client/agent-http.ts",
    "test:agent-sse": "npx tsx client/agent-sse.ts",
    "test:runtime": "npx tsx scripts/test-runtime.ts",
    "start:mcp:http": "npx tsx scripts/start-mcp-http.ts",
    "start": "tsx src/start.ts",
    "dev": "tsx watch src/start.ts | pino-pretty -i time,hostname,pid",
    "test": "npm run test:http-fetch",
    "postinstall": "pikku all",
    "stackblitz": "concurrently 'pikku watch --silent' 'npm run dev'"
  },
  "main": "src/start.ts",
  "exports": {
    ".": "./src/start.ts"
  },
  "stackblitz": {
    "startCommand": "npm run stackblitz"
  }
}